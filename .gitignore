# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Project Subdirectory Dependencies & Builds ---
# This will catch node_modules and builds at the root or inside backend/ and frontend/
node_modules/
.next/
out/
build/
dist/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Backend Specifics ---
# Ignores local environment files and user upload directories
.env
.env.local
.env.*.local
backend/.env
backend/.env.example
uploads/
backend/uploads/

# If you use SQLite with Prisma, untoggle this line:
# *.db

# --- Testing & Coverage ---
coverage/

# --- Misc System Files ---
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# --- Debug Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Vercel ---
.vercel

# --- Local Documentation ---
MD Files/
/MD Files/